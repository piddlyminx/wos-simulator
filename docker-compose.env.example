# Copy to `.env` (gitignored). `docker compose` loads it automatically.

# Local host port published by the optional Docker dev app.
APP_PORT=3000

# Turbopack file-watch polling interval in milliseconds for WSL2/SMB/NFS-backed
# bind mounts. Set to 0 to disable polling when native file notifications work.
NEXT_WATCH_POLL_INTERVAL_MS=1000
