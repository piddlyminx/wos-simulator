# Copy to `.env` (gitignored). `docker compose` loads it automatically.
#
# One-time tunnel setup — all in the Cloudflare Zero Trust dashboard, nothing
# on this host:
#
#   1. https://one.dash.cloudflare.com/ → Networks → Tunnels → Create a tunnel
#      (Cloudflared connector type).
#   2. Name it something like "wos-sim", click Save.
#   3. On the "Install and run a connector" step, copy the token — it is the
#      long string right after `--token ` in the generated install command.
#      That full string is your TUNNEL_TOKEN.
#   4. Click Next → Public Hostname tab → add:
#        - Subdomain: wos-sim
#        - Domain:    ratme.org          (must be in your CF account)
#        - Service:   HTTP  http://app:3000
#      The "app" hostname is the docker-compose service name; cloudflared
#      reaches it over the internal docker network. `wos-sim.ratme.org`
#      becomes the public URL.
#   5. Paste the token into TUNNEL_TOKEN below.
#
# After that, `docker compose up -d --build` brings everything up and the DNS
# record is auto-provisioned by Cloudflare. Changing the hostname later is a
# dashboard-only edit — no redeploy needed.

# Long token string from the Zero Trust dashboard. The only secret here.
TUNNEL_TOKEN=

# Local host port published by the app service (the tunnel uses the internal
# docker network and does not rely on this).
APP_PORT=3000
